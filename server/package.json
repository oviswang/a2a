{
  "name": "@globefly/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && tsx --tsconfig tsconfig.json src/index.ts",
    "start": "node --import tsx src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@globefly/shared": "*",
    "@prisma/client": "^6.4.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "nanoid": "^5.1.2",
    "socket.io": "^4.8.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
