generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model World {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  globeRadius Float    @default(5.0)
  texture     String   @default("earth")
  seed        Int      @default(0)
  terrainType String   @default("default")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LanternLedger {
  id        String   @id @default(cuid())
  count     Int
  worldSlug String
  createdAt DateTime @default(now())
}

/** Recent “player saved world” lines for the main menu feed (not player-specific). */
model SaveFeedEntry {
  id         String   @id @default(cuid())
  playerName String
  worldName  String
  worldSlug  String
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

/** Milestone-only history for dashboards; never high-frequency telemetry. */
model GameEvent {
  id             String   @id @default(cuid())
  type           String
  playerName     String
  worldSlug      String
  worldName      String?
  vehicle        String?
  level          Int?
  runDurationSec Int?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([worldSlug, createdAt(sort: Desc)])
}
